# =============================================================================
# StockAI Funnel — 三层决策系统 .gitignore
# =============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# ⚠️  敏感文件（API Key / Webhook，绝不上传）
# ──────────────────────────────────────────────────────────────────────────────
scripts/tokens.py
scripts/ts_token.py
config.json
ai_config.json
*.env
.env.*

# ──────────────────────────────────────────────────────────────────────────────
# 数据库与数据文件（本地数据，体积大，不纳入版本管理）
# ──────────────────────────────────────────────────────────────────────────────
db/
data/
stock_cache/
reports/
models/

# ──────────────────────────────────────────────────────────────────────────────
# 日志文件
# ──────────────────────────────────────────────────────────────────────────────
logs/
*.log

# ──────────────────────────────────────────────────────────────────────────────
# Python 构建产物
# ──────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
.pytest_cache/
.mypy_cache/
*.egg-info/
dist/
build/
.eggs/

# ──────────────────────────────────────────────────────────────────────────────
# 临时 / 调试文件
# ──────────────────────────────────────────────────────────────────────────────
check_
check_db.py
test_v4.py
test_run.py
test_ai_analysis.py
test_share_capital.py
test_tushare_permission.py

# ──────────────────────────────────────────────────────────────────────────────
# 操作系统 & 编辑器
# ──────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
